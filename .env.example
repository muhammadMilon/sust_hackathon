# Copy to .env for local runs. NEVER commit a real .env (it is gitignored).
# The service runs fully on the rules engine with NONE of these set.

# Port the HTTP server binds to (most platforms inject this automatically).
PORT=3000
HOST=0.0.0.0

# ---- Optional Claude LLM path (off by default) ----
# Set BOTH of the next two AND run `npm install @anthropic-ai/sdk` to enable.
# USE_LLM=true
# ANTHROPIC_API_KEY=sk-ant-...

# Optional LLM overrides (defaults shown):
# QUEUESTORM_MODEL=claude-opus-4-8
# QUEUESTORM_MAX_TOKENS=512
# QUEUESTORM_LLM_TIMEOUT_MS=12000
